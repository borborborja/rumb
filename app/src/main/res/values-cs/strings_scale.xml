    <string name="scale_meaning_bmi">Váha vzhledem k výšce. Hrubý údaj, slepý ke svalům vs. tuku.</string>
    <string name="scale_meaning_fat">Podíl váhy, který tvoří tuk. Málo je stejně nezdravé jako moc.</string>
    <string name="scale_meaning_water">Podíl těla, který tvoří voda. Klesá při dehydrataci.</string>
    <string name="scale_meaning_muscle">Celkové svaly. Rostou se silovým tréninkem.</string>
    <string name="scale_meaning_bone">Odhad kostní minerální hmoty. Mění se velmi pomalu.</string>
    <string name="scale_meaning_visceral">Tuk kolem orgánů. Číslo, které je dobré držet nízko.</string>
    <string name="scale_meaning_bmr">Kalorie, které tělo spálí v úplném klidu.</string>
    <string name="scale_meaning_protein">Podíl těla tvořený bílkovinami, spjatý se svaly.</string>
    <string name="scale_meaning_metabolic_age">Tvůj metabolismus ve srovnání s běžnými věky. Nižší je lepší.</string>
