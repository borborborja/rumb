    <string name="scale_meaning_protein">Udział ciała będący białkiem, powiązany z mięśniami.</string>
    <string name="scale_meaning_metabolic_age">Twój metabolizm w porównaniu z typowym wiekiem. Niższy jest lepszy.</string>
