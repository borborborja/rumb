<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
      Package visibility (API 30+). OpenTracks ships under several applicationIds (release
      `de.dennisguse.opentracks`, nightly `.debug`, plus forks). We can't enumerate them all, so we
      request QUERY_ALL_PACKAGES to DISCOVER whichever install exposes the public recording API by
      scanning for an activity ending in `.publicapi.StartRecording`. This is off-Play distribution
      (GitHub Releases), where QUERY_ALL_PACKAGES is acceptable. The <queries> entries keep the known
      packages visible even on devices where broad visibility is restricted.
    -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <queries>
        <package android:name="de.dennisguse.opentracks" />
        <package android:name="de.dennisguse.opentracks.debug" />
        <package android:name="de.dennisguse.opentracks.play" />
        <package android:name="de.dennisguse.opentracks.playstore" />
        <package android:name="de.dennisguse.opentracks.nightly" />
    </queries>

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Show the user's position and let the "locate" control center on it. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <!-- Required to install the downloaded APK update (off-Play distribution). -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <!-- Foreground download of offline map tiles + its progress notification. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Native activity recording: GPS keeps running with the screen off. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <!-- BLE fitness sensors (heart rate / cadence / power) for the native recorder. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30" />
    <!-- Off-route haptic alert. -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:name=".RumbApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.Rumb">

        <!-- Management app entry point -->
        <activity
            android:name=".manager.ManagerActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Open a track file (Open with Rumb) — by MIME type. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/vnd.garmin.tcx+xml" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="text/xml" />
            </intent-filter>
            <!-- Open a track file — by extension (file:// senders that omit a MIME type). -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="content" />
                <data android:scheme="file" />
                <data android:host="*" />
                <data android:pathPattern=".*\\.gpx" />
                <data android:pathPattern=".*\\.tcx" />
                <data android:pathPattern=".*\\.kml" />
                <data android:pathPattern=".*\\.kmz" />
            </intent-filter>
            <!-- Share a track into Rumb (from another app or another Rumb). -->
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="application/gpx+xml" />
                <data android:mimeType="application/vnd.garmin.tcx+xml" />
                <data android:mimeType="application/vnd.google-earth.kml+xml" />
                <data android:mimeType="application/vnd.google-earth.kmz" />
                <data android:mimeType="application/octet-stream" />
                <data android:mimeType="text/xml" />
            </intent-filter>
        </activity>

        <!-- Map viewer / OpenTracks dashboard receiver -->
        <activity
            android:name=".viewer.MapViewerActivity"
            android:exported="true"
            android:label="@string/viewer_title"
            android:launchMode="singleTask">
            <!-- NOTE: action string must match APIConstants.ACTION_DASHBOARD -->
            <intent-filter>
                <action android:name="Intent.OpenTracks-Dashboard" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Native activity recording engine (GPS foreground service). -->
        <service
            android:name=".data.recording.RecordingService"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Declare the foreground-service type for WorkManager's foreground worker (offline map download). -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge"
            xmlns:tools="http://schemas.android.com/tools" />

        <!-- Serves the downloaded APK to the system installer via a content:// URI. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
